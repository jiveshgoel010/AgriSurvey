    <string name="irrigation_type_usage">सिंचाई प्रकार उपयोग</string>
    <string name="irrigation_type_desc">किसानों द्वारा उपयोग की जाने वाली विभिन्न सिंचाई विधियों का विवरण।</string>
    <string name="cropping_pattern_trends">फसल पैटर्न रुझान</string>
    <string name="cropping_pattern_desc">सर्वेक्षण किये गये खेतों में प्रयुक्त फसल पैटर्न के प्रकारों को प्रदर्शित करता है।</string>
    <string name="landholding_size_distribution">भूमि स्वामित्व आकार वितरण</string>
    <string name="landholding_size_desc">यह दर्शाता है कि भूमि-स्वामित्व विभिन्न आकार श्रेणियों में किस प्रकार वितरित है।</string>
